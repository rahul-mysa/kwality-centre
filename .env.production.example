# Database (matches docker-compose db service)
DATABASE_URL=postgresql://kwality:changeme@db:5432/kwality_centre

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=https://your-domain.com/auth/google/callback

# Domain restriction
ALLOWED_DOMAINS=getmysa.com

# Admin emails (auto-promoted on first login)
ADMIN_EMAILS=you@getmysa.com

# GitHub (optional, for automated tests)
GITHUB_TOKEN=ghp_your-token

# API key (optional, for automated results upload)
KC_API_KEY=your-api-key

# App
SESSION_SECRET=generate-a-random-64-char-string
NODE_ENV=production
PORT=3000
